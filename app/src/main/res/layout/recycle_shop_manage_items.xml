<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/g1"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.3"
        />
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/img_product"
        android:layout_width="100dp"
        android:layout_height="120dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@+id/g1"
        app:layout_constraintHorizontal_bias="0"
        android:src="@drawable/vay_2"
        android:scaleType="centerCrop"
        />
    <TextView
        android:id="@+id/nameProduct_txt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"

        app:layout_constraintLeft_toRightOf="@id/g1"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/profits_txt"
        app:layout_constraintHorizontal_bias="0"

        android:text="name_product"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textAllCaps="true"

        android:fontFamily="sans-serif"
        android:textFontWeight="400"

        />
    <TextView
        android:id="@+id/profits_txt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"

        app:layout_constraintLeft_toRightOf="@id/g1"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/nameProduct_txt"
        app:layout_constraintBottom_toTopOf="@id/dateReserved_txt"
        app:layout_constraintHorizontal_bias="0"

        android:text="Doanh Thu đơn hàng"
        android:textColor="@color/black"
        android:textSize="13sp"

        android:fontFamily="sans-serif"
        android:textFontWeight="300"
        />
    <TextView
        android:id="@+id/dateReserved_txt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"

        app:layout_constraintLeft_toRightOf="@id/g1"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/profits_txt"
        app:layout_constraintHorizontal_bias="0"

        android:text="Thương hiệu"
        android:textColor="@color/black"
        android:textSize="13sp"

        android:fontFamily="sans-serif"
        android:textFontWeight="300"
        />
    <TextView
        android:id="@+id/state_txt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"

        app:layout_constraintLeft_toRightOf="@id/g1"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/dateReserved_txt"
        app:layout_constraintHorizontal_bias="0"

        android:text="Đáng giá"
        android:textColor="@color/black"
        android:textSize="13sp"

        android:fontFamily="sans-serif"
        android:textFontWeight="300"
        />
    <com.google.android.material.button.MaterialButton
        android:id="@+id/state_btn"
        android:layout_width="0dp"
        app:layout_constraintWidth_percent="0.25"
        android:layout_height="35dp"
        android:layout_marginTop="15dp"

        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintBottom_toTopOf="@id/cancel_btn"
        app:layout_constraintHorizontal_bias="0.9"


        android:text="Chỉnh sửa"
        android:backgroundTint="@color/MainColor"
        app:cornerRadius="15dp"
        android:textColor="@color/white"
        android:textAllCaps="false"
        android:textSize="8sp"

        />
    <com.google.android.material.button.MaterialButton
        android:id="@+id/cancel_btn"
        android:layout_width="0dp"
        app:layout_constraintWidth_percent="0.25"
        android:layout_height="35dp"

        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/state_btn"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintHorizontal_bias="0.9"

        android:text="Xoá"
        android:backgroundTint="@color/white"
        app:cornerRadius="15dp"
        android:textColor="@color/MainColor"
        app:strokeColor="@color/MainColor"
        app:strokeWidth="1dp"
        android:textAllCaps="false"
        android:textSize="8sp"

        />

</androidx.constraintlayout.widget.ConstraintLayout>